# Django settings
SECRET_KEY=django-insecure-your-secret-key-here

# Database settings
# If DB_NAME is left empty, the project will automatically fall back to SQLite (db.sqlite3)
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=

# AWS S3 settings
# If AWS_STORAGE_BUCKET_NAME is left empty, the project will fall back to local file storage for static/media files
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
